# ngrok
NGROK_AUTHTOKEN=

# OpenAI (LLM: transcript insights + natural-language survey draft API; Whisper STT in CLI)
OPENAI_API_KEY=
# Used by lib/survey/nl-draft and other server LLM calls when set
LLM_MODEL=gpt-4o-mini

# Vapi
VAPI_PRIVATE_KEY=
# Set one of these:
VAPI_PHONE_NUMBER_ID=
VAPI_FROM_NUMBER=+12707976845
VAPI_WEBHOOK_SECRET=
# Optional Vapi tuning (latency + quality). Default LLM: OpenAI gpt-4o via Vapi (configure OpenAI in Vapi dashboard).
# For faster/cheaper: VAPI_MODEL_NAME=gpt-4o-mini. Legacy Groq: VAPI_MODEL_PROVIDER=groq VAPI_MODEL_NAME=openai/gpt-oss-120b
VAPI_MODEL_PROVIDER=openai
VAPI_MODEL_NAME=gpt-4o
VAPI_MODEL_TEMPERATURE=0.3
VAPI_VOICE_SPEED=0.98
VAPI_VOICE_STABILITY=0.5
VAPI_VOICE_SIMILARITY=0.8
VAPI_WAIT_SECONDS=0.6
# PSTN outbound: pause before speaking so iPhone/call screening isn’t talked over
VAPI_OUTBOUND_WAIT_SECONDS=1.35
VAPI_RESPONSE_DELAY_SECONDS=0.28
VAPI_STOP_WORDS=2
VAPI_STOP_VOICE_SECONDS=0.2
VAPI_STOP_BACKOFF_SECONDS=0.8

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vapi Web SDK (public key for browser voice test)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App URL (for webhooks when deployed)
NEXT_PUBLIC_APP_URL=
